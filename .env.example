# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Cloudflare R2 Worker ──────────────────────────────────────────────────────
# Your deployed Worker URL (from Cloudflare dashboard → Workers → your worker)
R2_WORKER_URL=https://your-worker.your-account.workers.dev

# API key — must match the API_KEY value in r2_storage_script.js
R2_API_KEY=sai-r2-secret-2026
